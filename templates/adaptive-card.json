{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.4",
        "body": [
          {
            "type": "TextBlock",
            "text": " Windows Health Check Report",
            "weight": "Bolder",
            "size": "Large",
            "color": "Accent"
          },

          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  { "type": "TextBlock", "text": " IIS Service", "weight": "Bolder" }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{ service_icon }} {{ health.ServiceStatus }}",
                    "color": "{{ service_color }}"
                  }
                ]
              }
            ]
          },

          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  { "type": "TextBlock", "text": " Website", "weight": "Bolder" }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{ web_icon }} {{ health.WebStatus }}",
                    "color": "{{ web_color }}"
                  }
                ]
              }
            ]
          },

          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  { "type": "TextBlock", "text": " CPU Usage", "weight": "Bolder" }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{ cpu_icon }} {{ health.CPU }}",
                    "color": "{{ cpu_color }}"
                  }
                ]
              }
            ]
          },

          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  { "type": "TextBlock", "text": " Memory", "weight": "Bolder" }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{ memory_icon }} {{ health.Memory }}",
                    "color": "{{ memory_color }}"
                  }
                ]
              }
            ]
          },

          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  { "type": "TextBlock", "text": " Disk C:", "weight": "Bolder" }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{ disk_icon }} {{ health.Disk }}",
                    "color": "{{ disk_color }}"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
